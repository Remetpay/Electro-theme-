<section class="section">
  <div class="section-heading"><span class="eyebrow">Search</span><h1>Search Gadget GRV</h1><p>Find smart gadgets, accessories, audio, gaming gear, smart home products, wearables, and charging essentials.</p></div>
  <form action="{{ routes.search_url }}" method="get" role="search" style="max-width:760px;margin-bottom:28px"><input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products"><button class="btn primary" type="submit" style="margin-top:12px">Search</button></form>
  {% if search.performed %}<div class="product-grid">{% for item in search.results %}{% if item.object_type == 'product' %}{% render 'product-card', product: item %}{% endif %}{% else %}<p>No results found.</p>{% endfor %}</div>{% endif %}
</section>
{% schema %}
{"name":"Main search","settings":[]}
{% endschema %}
