<section class="hero" id="top">
  <div class="hero-copy">
    <span class="pill">✦ Futuristic tech, curated for daily life</span>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
    <div class="hero-ctas"><a href="{{ section.settings.primary_link }}" class="btn primary">{{ section.settings.primary_label }}</a><a href="{{ section.settings.secondary_link }}" class="btn">{{ section.settings.secondary_label }}</a></div>
    <div class="microtrust"><span>Free shipping on eligible orders</span><span>Secure checkout</span><span>Easy returns</span></div>
  </div>
  <div class="hero-visual"><div class="device-shell"><div class="device-screen"><div class="orb"></div><span>GRV OS</span><strong>Smart Tech Hub</strong><small>Connected • Charged • Ready</small></div></div><div class="floating-chip chip-a">ANC Audio</div><div class="floating-chip chip-b">30W Fast Charge</div><div class="floating-chip chip-c">Smart Home Ready</div></div>
</section>
<section class="trust-bar"><div>🚚 Fast Worldwide Shipping</div><div>🔒 Secure Checkout</div><div>↩ Easy Returns</div><div>🎧 Premium Support</div><div>✓ Quality Checked Products</div></section>
<section class="section"><div class="section-heading"><span class="eyebrow">Shop By Category</span><h2>Find the right upgrade faster.</h2><p>Focused collections prevent the generic marketplace feel and help buyers self-segment instantly.</p></div><div class="category-grid">
{% assign labels = 'Phone Accessories|Smart Gadgets|Wireless Audio|Gaming Accessories|Smart Home|Wearables|Charging Essentials|Trending Electronics' | split: '|' %}
{% for label in labels %}<article class="category-card glass-card"><span class="eyebrow">0{{ forloop.index }}</span><h3>{{ label }}</h3><p>Premium curated tech essentials for {{ label | downcase }}.</p><a href="/collections/all">Explore →</a></article>{% endfor %}
</div></section>
<section class="section"><div class="section-heading"><span class="eyebrow">Best Sellers</span><h2>Premium gadgets with visible reasons to buy.</h2><p>Each card supports Shopify product data, variants, quick add, sale pricing, and product images.</p></div><div class="product-grid">
{% assign featured_collection = collections[section.settings.featured_collection] %}
{% if featured_collection.products_count > 0 %}{% for product in featured_collection.products limit: 8 %}{% render 'product-card', product: product %}{% endfor %}{% else %}{% for product in collections.all.products limit: 8 %}{% render 'product-card', product: product %}{% endfor %}{% endif %}
</div></section>
<section class="deal-banner"><div><span class="eyebrow">Limited Time Deals</span><h2>Save up to 30% on trending gadgets and tech essentials.</h2><p>Conversion-focused urgency, trust reinforcement, and a direct path to sale products.</p></div><div class="countdown"><span><strong>02</strong>Days</span><span><strong>18</strong>Hrs</span><span><strong>42</strong>Min</span></div><a class="btn primary" href="{{ section.settings.deal_link }}">Shop Deals</a></section>
<section class="section"><div class="section-heading"><span class="eyebrow">Why Shop Gadget GRV</span><h2>Premium trust signals without the dropship noise.</h2></div><div class="benefit-grid">{% assign benefits = 'Curated Tech Essentials|Quality Checked Products|Secure Payments|Responsive Customer Support|Easy Returns|Fast Order Processing' | split: '|' %}{% for benefit in benefits %}<article class="benefit glass-card"><h3>{{ benefit }}</h3><p>Clear, credible purchase reassurance designed for premium electronics shoppers.</p></article>{% endfor %}</div></section>
<section class="section"><div class="section-heading"><span class="eyebrow">Product Discovery</span><h2>Multiple paths to purchase.</h2></div><div class="discovery-grid">{% assign cards = 'New Arrivals|Trending Now|Under $50|Premium Picks' | split: '|' %}{% for card in cards %}<article class="discovery-card glass-card"><h3>{{ card }}</h3><p>Curated product path built to reduce friction and increase add-to-cart intent.</p><a href="/collections/all">View edit →</a></article>{% endfor %}</div></section>
<section class="section"><div class="section-heading"><span class="eyebrow">Customer Reviews</span><h2>Social proof with enough specificity to feel credible.</h2></div><div class="review-grid">{% for block in section.blocks %}<article class="review-card glass-card" {{ block.shopify_attributes }}><span class="stars">★★★★★</span><p>“{{ block.settings.review }}”</p><strong>{{ block.settings.name }}</strong></article>{% endfor %}</div></section>
<section class="newsletter"><span class="eyebrow">Stay Ahead of the Next Drop</span><h2>Get exclusive deals, product launches, and gadget updates delivered to your inbox.</h2>{% form 'customer' %}<input type="hidden" name="contact[tags]" value="newsletter"><input type="email" name="contact[email]" placeholder="Enter your email" required><button class="btn primary" type="submit">Join the List</button>{% endform %}</section>
{% schema %}
{"name":"Gadget GRV homepage","settings":[{"type":"text","id":"heading","label":"Heading","default":"Upgrade Your Everyday Tech"},{"type":"textarea","id":"subheading","label":"Subheading","default":"Discover smart gadgets, premium accessories, and next-gen electronics built for convenience, performance, and style."},{"type":"text","id":"primary_label","label":"Primary button","default":"Shop Best Sellers"},{"type":"url","id":"primary_link","label":"Primary link","default":"/collections/all"},{"type":"text","id":"secondary_label","label":"Secondary button","default":"Explore New Arrivals"},{"type":"url","id":"secondary_link","label":"Secondary link","default":"/collections/all"},{"type":"collection","id":"featured_collection","label":"Best sellers collection"},{"type":"url","id":"deal_link","label":"Deals link","default":"/collections/all"}],"blocks":[{"type":"review","name":"Review","settings":[{"type":"text","id":"name","label":"Name","default":"Maya R."},{"type":"textarea","id":"review","label":"Review","default":"The store feels premium and the product cards make it easy to compare quickly."}]}],"presets":[{"name":"Gadget GRV homepage","blocks":[{"type":"review"},{"type":"review","settings":{"name":"Jordan K.","review":"Bought earbuds and a power bank. The experience felt curated instead of random."}},{"type":"review","settings":{"name":"Anika S.","review":"The deal section and trust badges gave me confidence to add more to cart."}},{"type":"review","settings":{"name":"Leo T.","review":"The under-$50 discovery path is excellent for gifting."}}]}]}
{% endschema %}
