<footer class="site-footer">
  <div class="columns">
    <div>
      <h4>Shop</h4>
      {% for link in linklists.footer.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </div>

    <div>
      <h4>Support</h4>
      <a href="/help">Help Center</a>
      <a href="/returns">Returns</a>
    </div>
  </div>

  <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}