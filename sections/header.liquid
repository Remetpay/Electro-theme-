<header class="site-header">
  <a class="logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }} home"><span class="logo-mark">G</span>{{ section.settings.logo_text }}</a>
  <nav class="desktop-nav" aria-label="Primary navigation">
    {% for link in linklists[section.settings.menu].links %}<a href="{{ link.url }}">{{ link.title }}</a>{% endfor %}
  </nav>
  <div class="header-actions">
    <a class="icon-btn" href="{{ routes.search_url }}" aria-label="Search">⌕</a>
    <a class="icon-btn icon-account" href="{{ routes.account_url }}" aria-label="Account">◎</a>
    <button class="icon-btn" type="button" data-open-cart aria-label="Cart">🛍<span class="cart-count">{{ cart.item_count }}</span></button>
  </div>
</header>
{% schema %}
{"name":"Header","settings":[{"type":"text","id":"logo_text","label":"Logo text","default":"Gadget GRV"},{"type":"link_list","id":"menu","label":"Menu","default":"main-menu"}]}
{% endschema %}
